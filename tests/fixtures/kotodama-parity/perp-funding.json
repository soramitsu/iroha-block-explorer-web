  "source": "// Perpetual swap funding and simple liquidation check utilities.\nseiyaku PerpFunding {\n  // Compute funding payment: position_size * (mark - index) * funding_bps / 10_000\n  fn funding_payment(position_size: int, mark_price: int, index_price: int, funding_bps: int) -> int {\n    let delta = mark_price - index_price;\n    let num = position_size * delta * funding_bps;\n    let pay = num / 10_000;\n    return pay;\n  }\n\n  // Update position balance by transferring funding between trader and insurance_fund.\n  // Positive payment means trader pays; negative means trader receives.\n  kotoage fn settle_funding(trader: AccountId,\n                            insurance_fund: AccountId,\n                            stable_asset: AssetDefinitionId,\n                            position_size: int,\n                            mark_price: int,\n                            index_price: int,\n                            funding_bps: int) permission(Admin) {\n    let pay = funding_payment(position_size, mark_price, index_price, funding_bps);\n    if pay > 0 {\n      transfer_asset(trader, insurance_fund, stable_asset, pay);\n    } else {\n      let receive = 0 - pay; // absolute value\n      transfer_asset(insurance_fund, trader, stable_asset, receive);\n    }\n  }\n\n  // Basic liquidation check: equity_bps = (equity * 10_000) / notional\n  kotoage fn is_liquidatable(equity: int, notional: int, maintenance_bps: int) -> int {\n    if notional == 0 { return 0; } // not liquidatable if no position\n    let equity_bps = (equity * 10_000) / notional;\n    let liq = (equity_bps < maintenance_bps);\n    return liq; // returns 1 if true, 0 if false\n  }\n}\n",
