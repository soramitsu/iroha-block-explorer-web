  "source": "// Kotodama sample: placeholder for ZK verify + unshield flow\n// Note: This sample demonstrates structure and logging; real ZK verify intrinsics\n// may differ and depend on backend features. Use CLI helpers to submit Unshield ISIs.\n\nseiyaku ZkUnshieldDemo {\n  meta {\n    abi_version: 1,\n    features: [\"zk\"],\n    max_cycles: 0,\n  }\n\n  kotoage fn run() permission(Admin) {\n    info(\"ZkUnshieldDemo: preparing pointers\");\n    let to = account!(\"sorauﾛ1PaQｽGh1ｴ6pAﾜnqｸfJuｿMﾑVqﾏvQﾐﾚｼｾﾋaﾈｳﾊc1ｺﾊ1GGM2D\");\n    let ad = asset_definition!(\"62Fk4FPcMuLvW5QjDGNF2a4jAmjM\");\n\n    // In a real program, you would pass proof envelopes via NoritoBytes and\n    // call zk verification builtins (backend-specific) prior to recording state.\n    // Here we log placeholders to illustrate pointer-ABI usage.\n    let proof = norito_bytes(\"ENV-UNSHIELD\"); // minimal envelope magic as a placeholder\n    let vk_name = name!(\"vk_unshield\");\n\n    info(\"ZkUnshieldDemo: (placeholder) would verify proof with vk_unshield\");\n    zk_verify_unshield(proof);\n    // Example: tag detail to signal an attempted unshield (demo only)\n    set_account_detail(to, vk_name, json!{ attempt: true });\n    info(\"ZkUnshieldDemo: done\");\n  }\n}\n",
