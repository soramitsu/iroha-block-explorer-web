  "source": "seiyaku PredictionMarket {\n  meta {\n    abi_version: 1,\n    max_cycles: 200000,\n  }\n\n  // Fixed-size demo market: two bettors (Alice/Bob) and two oracle keys (YES/NO).\n  // Durable state guards prevent double-staking or double-resolution.\n  state bool alice_staked;\n  state bool bob_staked;\n  state bool resolved;\n\n  hajimari() {\n    alice_staked = false;\n    bob_staked = false;\n    resolved = false;\n  }\n  kotoage fn main() permission(MarketUser) {\n    let caller = authority();\n    let asset = asset_definition(\"61CtjvNd9T3THAR65GsMVHr82Bjc\");\n    let pool = account_id(\"sorauﾛ1NﾗhBUd2BﾂｦﾄiﾔﾆﾂﾇKSﾃaﾘﾒﾓQﾗrﾒoﾘﾅnｳﾘbQｳQJﾆLJ5HSE\");\n    let alice = account_id(\"sorauﾛ1Npﾃﾕヱﾇq11pｳﾘ2ｱ5ﾇｦiCJKjRﾔzｷNMNﾆｹﾕPCｳﾙFvｵE9LBLB\");\n    let bob = account_id(\"sorauﾛ1NfｷgﾉﾓﾉBｦKﾌﾘﾒoﾇﾂﾛrG81ﾋjWﾎﾕVncwﾌSｱ3pﾘﾋﾉhUS9Q76\");\n    let oracle_yes = account_id(\"sorauﾛ1Q2ｸBKzrｼStﾊYyXﾌ1ｹHｿｾkSveﾉyｻﾈHﾗｿug7zWﾑヰyRMH888\");\n    let oracle_no = account_id(\"sorauﾛ1PaQｽGh1ｴ6pAﾜnqｸfJuｿMﾑVqﾏvQﾐﾚｼｾﾋaﾈｳﾊc1ｺﾊ1GGM2D\");\n\n    if (caller == oracle_yes) {\n      if (!resolved && alice_staked && bob_staked) {\n        transfer_asset(pool, alice, asset, 20);\n        resolved = true;\n      }\n      return;\n    }\n    if (caller == oracle_no) {\n      if (!resolved && alice_staked && bob_staked) {\n        transfer_asset(pool, bob, asset, 20);\n        resolved = true;\n      }\n      return;\n    }\n    if (caller == alice) {\n      if (!resolved && !alice_staked) {\n        transfer_asset(caller, pool, asset, 10);\n        alice_staked = true;\n      }\n      return;\n    }\n    if (caller == bob) {\n      if (!resolved && !bob_staked) {\n        transfer_asset(caller, pool, asset, 10);\n        bob_staked = true;\n      }\n      return;\n    }\n  }\n}\n",
