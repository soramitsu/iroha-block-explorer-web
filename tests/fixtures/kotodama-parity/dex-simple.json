  "source": "// Simple constant-product DEX helpers (no persistent state yet).\n// Demonstrates arithmetic, conditionals, returns, and syscalls.\nseiyaku DexSimple {\n  // Quote output amount for selling `amount_in` of input into output reserves.\n  fn quote_sell(reserve_in: int, reserve_out: int, amount_in: int) -> int {\n    // apply 0.3% fee\n    let effective = (amount_in * 997) / 1000;\n    let numerator = reserve_out * effective;\n    let denominator = reserve_in + effective;\n    let out = numerator / denominator;\n    return out;\n  }\n\n  // Perform a swap by moving tokens between trader and a pool account.\n  // In a full implementation, `pool_account` would be derived from contract state.\n  kotoage fn swap(trader: AccountId,\n                  pool_account: AccountId,\n                  input_asset: AssetDefinitionId,\n                  output_asset: AssetDefinitionId,\n                  amount_in: int,\n                  reserve_in: int,\n                  reserve_out: int) -> int permission(Admin) {\n    let out = quote_sell(reserve_in, reserve_out, amount_in);\n    // move input from trader to pool, and output from pool to trader\n    transfer_asset(trader, pool_account, input_asset, amount_in);\n    transfer_asset(pool_account, trader, output_asset, out);\n    return out;\n  }\n\n  // Deterministic order id using a Poseidon hash of (trader, salt).\n  kotoage fn order_id(trader: int, salt: int) -> int {\n    let h = poseidon2(trader, salt);\n    return h;\n  }\n}\n",
