  "source": "// Minimal Kotodama example: logs a greeting and writes a detail for the current authority\n\nseiyaku Hello {\n  // Optional initializer; deploy-oriented runtimes may call this automatically.\n  hajimari() {\n    info(\"Hello from Kotodama\");\n  }\n\n  // Default raw-IVM entrypoint used by ivm_run / transaction ivm when no selector is supplied.\n  kotoage fn main() permission(Admin) {\n    info(\"Hello from Kotodama\");\n    write_detail();\n  }\n\n  // Public entrypoint that sets an account detail on the caller.\n  kotoage fn write_detail() permission(Admin) {\n    set_account_detail(\n      authority(),\n      name!(\"example\"),\n      json!{ hello: \"world\" }\n    );\n  }\n}\n",
