  "source": "// Kotodama sample: shield-like host interaction demo (logs and asset ops)\n\nseiyaku ZkShieldDemo {\n  meta {\n    abi_version: 1,\n    features: [\"zk\"],\n    max_cycles: 0,\n  }\n\n  // Public entrypoint: demonstrates pointer constructors and host calls\n  kotoage fn run() permission(Admin) {\n    let who = account!(\"sorauﾛ1PaQｽGh1ｴ6pAﾜnqｸfJuｿMﾑVqﾏvQﾐﾚｼｾﾋaﾈｳﾊc1ｺﾊ1GGM2D\");\n    let ad = asset_definition!(\"62Fk4FPcMuLvW5QjDGNF2a4jAmjM\");\n\n    info(\"ZkShieldDemo: start\");\n    let proof_env = norito_bytes(\"ENV-SHIELD\");\n    zk_verify_transfer(proof_env);\n    // Example: set an account detail (host syscall)\n    set_account_detail(who, name!(\"zk_demo\"), json!{ run: true });\n    // Example: mint a tiny amount (host syscall)\n    mint_asset(who, ad, 1);\n    info(\"ZkShieldDemo: done\");\n  }\n}\n",
