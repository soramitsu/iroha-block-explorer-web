  "compiler_source_path": "crates/kotodama_lang/src/samples/lending_simple.ko",
  "source": "// Minimal lending market primitives.\n// Shows collateral ratio checks and minting borrowed asset.\nseiyaku LendingSimple {\n  // Compute collateralization ratio in basis points (bps = 1/100 of a percent).\n  fn collateral_ratio_bps(collateral_value: int, debt_value: int) -> int {\n    if debt_value == 0 { return 1_000_000; } // effectively infinite\n    let ratio = (collateral_value * 10_000) / debt_value;\n    return ratio;\n  }\n\n  // Borrow after checking ratio >= min_ratio_bps.\n  kotoage fn borrow(user: AccountId,\n                    _vault_account: AccountId,\n                    debt_asset: AssetDefinitionId,\n                    amount: int,\n                    collateral_value: int,\n                    current_debt_value: int,\n                    min_ratio_bps: int) permission(Admin) {\n    let new_debt_value = current_debt_value + amount;\n    let ratio = collateral_ratio_bps(collateral_value, new_debt_value);\n    // assert(ratio >= min_ratio_bps)\n    let ok = (ratio >= min_ratio_bps) ? 1 : 0;\n    // assert_eq emits a VM assertion; 1 means true\n    assert_eq(ok, 1);\n    // Mint borrowed asset to user\n    mint_asset(user, debt_asset, amount);\n  }\n\n  // Repay by transferring tokens from user to vault and burning.\n  kotoage fn repay(user: AccountId,\n                   vault_account: AccountId,\n                   debt_asset: AssetDefinitionId,\n                   amount: int) permission(Admin) {\n    transfer_asset(user, vault_account, debt_asset, amount);\n    burn_asset(vault_account, debt_asset, amount);\n  }\n}\n",
